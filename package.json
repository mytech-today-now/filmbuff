{
    "name": "@mytechtoday/filmbuff",
    "version": "1.0.1",
    "description": "CLI tool for managing writing, prose, and screenplay extension modules",
    "main": "cli/dist/index.js",
    "bin": {
        "filmbuff": "bin/filmbuff.js"
    },
    "files": [
        "bin/",
        "cli/dist/",
        "augment-extensions/writing-standards/",
        "augment-extensions/workflows/openspec/",
        "augment-extensions/workflows/beads/",
        "README.md",
        "LICENSE",
        "AGENTS.md",
        "modules.md"
    ],
    "scripts": {
        "build": "cd cli && tsc",
        "verify:dist": "node scripts/verify-dist.js",
        "dev": "cd cli && tsc --watch",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "validate:commercials": "npx tsx augment-extensions/writing-standards/screenplay/commercials/scripts/validate-character-count.ts",
        "validate:commercials:verbose": "npx tsx augment-extensions/writing-standards/screenplay/commercials/scripts/validate-character-count.ts --verbose",
        "validate:commercials:json": "npx tsx augment-extensions/writing-standards/screenplay/commercials/scripts/validate-character-count.ts --json",
        "prepare": "npm run verify:dist",
        "prepublishOnly": "npm run verify:dist",
        "install:cli": "npm install && npm run verify:dist && npm install -g .",
        "uninstall:cli": "npm uninstall -g @mytechtoday/filmbuff",
        "reinstall:cli": "npm run uninstall:cli && npm run install:cli"
    },
    "keywords": [
        "filmbuff",
        "writing",
        "screenplay",
        "prose",
        "shot-list",
        "ai",
        "augment-code",
        "extensions"
    ],
    "author": "Augment Extensions",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/mytech-today-now/filmbuff.git"
    },
    "bugs": {
        "url": "https://github.com/mytech-today-now/filmbuff/issues"
    },
    "homepage": "https://github.com/mytech-today-now/filmbuff#readme",
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/mytech-today-now"
        },
        {
            "type": "patreon",
            "url": "https://patreon.com/mytech_today"
        },
        {
            "type": "ko_fi",
            "url": "https://ko-fi.com/mytech_today"
        },
        "https://www.buymeacoffee.com/mytech_today"
    ],
    "engines": {
        "node": ">=16.0.0"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.78.0",
        "chalk": "^5.3.0",
        "commander": "^11.0.0",
        "csv-stringify": "^6.6.0",
        "fast-xml-parser": "^5.4.1",
        "gray-matter": "^4.0.3",
        "highlight.js": "^11.11.1",
        "js-yaml": "^4.1.1",
        "mammoth": "^1.11.0",
        "minimatch": "^10.1.1",
        "pdf-parse": "^1.1.1",
        "rtf-parser": "^1.3.3",
        "semver": "^7.5.0",
        "uuid": "^13.0.0",
        "yaml": "^2.3.0"
    },
    "devDependencies": {
        "@types/jest": "^30.0.0",
        "@types/node": "^20.19.33",
        "@types/semver": "^7.5.0",
        "@types/uuid": "^10.0.0",
        "jest": "^29.7.0",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    }
}
